# backend/.env.example
# Copy this file to .env and fill in your actual values.
# Never commit .env — it is listed in .gitignore.
#
# SECURITY: This file must contain ONLY placeholder values.
# Never put real API keys, tokens, or passwords here.

# ── Application ─────────────────────────────────────────────────────────────
APP_NAME=Medicare API
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true

# ── API routing ──────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1

# ── CORS — JSON array of allowed frontend origins ───────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Legacy single-origin variable (still read for display purposes)
FRONTEND_URL=http://localhost:3000

# ── Supabase (required) ──────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
# Never prefix these with NEXT_PUBLIC_ — they are backend-only secrets.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ── Gemini AI (required for assistant) ──────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
# Key must start with AIza — never prefix with NEXT_PUBLIC_.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
AI_PROVIDER=gemini
AI_REQUEST_TIMEOUT_SECONDS=30
AI_MAX_INPUT_CHARACTERS=4000
AI_MAX_HISTORY_MESSAGES=12
AI_TEMPERATURE=0.2
AI_ASSISTANT_ENABLED=true
AI_RATE_LIMIT_PER_MINUTE=10
AI_RATE_LIMIT_PER_DAY=100
AI_CONVERSATION_RETENTION_DAYS=30

# ── Hugging Face (Optional — disabled by default) ────────────────────────────
HF_TOKEN=your-hf-token-here
HF_CHAT_MODEL=
HF_INTENT_MODEL=
HF_PROVIDER_ENABLED=false

# ── Geoapify Places API (Optional — disabled by default) ─────────────────────
# Get your API key from: https://developer.geoapify.com/
# Never prefix with NEXT_PUBLIC_ — this is a backend-only secret.
GEOAPIFY_ENABLED=true
GEOAPIFY_API_KEY=your-geoapify-api-key-here
GEOAPIFY_TIMEOUT_SECONDS=10

# ── Twilio (Optional — disabled by default) ──────────────────────────────────
# Get credentials from: https://console.twilio.com
# Never prefix with NEXT_PUBLIC_ — backend-only secrets.
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_STATUS_CALLBACK_URL=https://your-backend.onrender.com/api/v1/twilio/status/message
TWILIO_CALL_TWIML_URL=https://your-backend.onrender.com/api/v1/twilio/voice/emergency-message
TWILIO_TIMEOUT_SECONDS=15

# ── Twilio (Optional — SMS and voice call alerts) ────────────────────────────
# Get credentials from: https://www.twilio.com/console
# Never prefix with NEXT_PUBLIC_ — backend-only secrets.
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# Optional: use a Messaging Service SID instead of a single number
TWILIO_MESSAGING_SERVICE_SID=
# Callback URL for delivery status updates (must be publicly accessible)
TWILIO_STATUS_CALLBACK_URL=https://your-backend.onrender.com/api/v1/twilio/status/message
# Public TwiML URL for outbound calls
TWILIO_CALL_TWIML_URL=https://your-backend.onrender.com/api/v1/twilio/voice/emergency-message
TWILIO_TIMEOUT_SECONDS=15
