# backend/.env.example
# Copy this file to .env and fill in your actual values.
# Never commit .env — it is listed in .gitignore.
#
# SECURITY: This file must contain ONLY placeholder values.
# Never put real API keys, tokens, or passwords here.

# ── Application ─────────────────────────────────────────────────────────────
APP_NAME=Medicare API
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true

# ── API routing ──────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1

# ── CORS — JSON array of allowed frontend origins ───────────────────────────
BACKEND_CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:3000"]

# Legacy single-origin variable (still read for display purposes)
FRONTEND_URL=http://localhost:3000

# ── Supabase (required) ──────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
# Never prefix these with NEXT_PUBLIC_ — they are backend-only secrets.
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── Gemini AI (required for assistant) ──────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
# Key must start with AIza — never prefix with NEXT_PUBLIC_.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
AI_PROVIDER=gemini
AI_REQUEST_TIMEOUT_SECONDS=30
AI_MAX_INPUT_CHARACTERS=4000
AI_MAX_HISTORY_MESSAGES=12
AI_TEMPERATURE=0.2
AI_ASSISTANT_ENABLED=true
AI_RATE_LIMIT_PER_MINUTE=10
AI_RATE_LIMIT_PER_DAY=100
AI_CONVERSATION_RETENTION_DAYS=30

# ── Hugging Face (Optional — disabled by default) ────────────────────────────
HF_TOKEN=YOUR_HF_TOKEN
HF_CHAT_MODEL=
HF_INTENT_MODEL=
HF_PROVIDER_ENABLED=false

# ── Geoapify Places API (hospitals) ─────────────────────────────────────────
# Get your API key from: https://developer.geoapify.com/
# Never prefix with NEXT_PUBLIC_ — this is a backend-only secret.
GEOAPIFY_ENABLED=true
GEOAPIFY_API_KEY=YOUR_GEOAPIFY_API_KEY
GEOAPIFY_TIMEOUT_SECONDS=10

# ── Google Places API (New) — pharmacy + ambulance search ───────────────────
# Steps to set up:
#   1. Open Google Cloud Console: https://console.cloud.google.com/
#   2. Create or select a project.
#   3. Enable "Places API (New)" — NOT the legacy Places API.
#   4. Enable billing on the project.
#   5. Go to APIs & Services → Credentials → Create API key.
#   6. Under API restrictions, restrict to "Places API (New)" only.
#   7. For production, restrict by Render server IP under Application restrictions.
#   8. Save the key ONLY in Render environment variables — NEVER in Vercel.
#   9. Redeploy the backend after adding the variable.
GOOGLE_PLACES_ENABLED=true
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY
GOOGLE_PLACES_TIMEOUT_SECONDS=10

# ── Twilio (Optional — SMS and voice call alerts) ────────────────────────────
# Get credentials from: https://console.twilio.com
# Never prefix with NEXT_PUBLIC_ — backend-only secrets.
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=YOUR_TWILIO_MESSAGING_SERVICE_SID
TWILIO_STATUS_CALLBACK_URL=https://your-backend.onrender.com/api/v1/twilio/status/message
TWILIO_CALL_TWIML_URL=https://your-backend.onrender.com/api/v1/twilio/voice/emergency-message
TWILIO_TIMEOUT_SECONDS=15
